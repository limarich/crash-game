generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Round {
  id            String      @id @default(uuid())
  crashPoint    Float       @map("crash_point")
  bettingEndsAt DateTime    @map("betting_ends_at")
  createdAt     DateTime    @default(now()) @map("created_at")
  status        RoundStatus @default(BETTING)
  clientSeed    String      @map("client_seed")
  startedAt     DateTime?   @map("started_at")
  crashedAt     DateTime?   @map("crashed_at")

  nonce          Int    @unique
  serverSeed     String @map("server_seed")
  serverSeedHash String @map("server_seed_hash")

  @@map("rounds")
}

model Bet {
  id                String    @id @default(uuid())
  roundId           String    @map("round_id")
  playerId          String    @map("player_id")
  amountInCents     BigInt    @map("amount_in_cents")
  createdAt         DateTime  @default(now()) @map("created_at")
  status            BetStatus @default(PENDING)
  cashoutMultiplier Float?    @map("cashout_multiplier")

  payoutInCents BigInt? @map("payout_in_cents")

  @@unique([playerId, roundId])
  @@map("bets")
}

enum RoundStatus {
  BETTING
  RUNNING
  CRASHED
}

enum BetStatus {
  PENDING
  CONFIRMED
  CANCELLED
  CASHED_OUT
  LOST
}
